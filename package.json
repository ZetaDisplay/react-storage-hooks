{
  "name": "@zetadisplay/react-storage-hooks",
  "version": "6.0.1",
  "description": "React hooks for persistent state. Forked from https://github.com/soyguijarro/react-storage-hooks, original author Ramón Guijarro <hola@soyguijarro.com>",
  "keywords": [
    "react",
    "react-hooks",
    "persistent",
    "useState",
    "useReducer",
    "storage",
    "localstorage",
    "sessionstorage"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "lint": "eslint src/*.ts",
    "fmt": "prettier --check --write *.md *.json src/*.ts",
    "types": "tsd",
    "test": "jest",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "test:staged": "npm test -- --findRelatedTests --bail",
    "prebuild": "del dist",
    "build": "tsc",
    "build:watch": "npm run build -- --watch",
    "size": "size-limit",
    "precheck": "npm run build",
    "check": "run-s lint fmt types test:coverage size",
    "examples:setup": "cd examples && npm install && npm link ../.",
    "examples:start": "cd examples && npm start",
    "examples:watch": "run-p build:watch examples:start",
    "prerelease": "npm run check",
    "release": "git push --follow-tags origin master",
    "prepare": "husky install"
  },
  "files": [
    "dist",
    "dist/index.d.ts"
  ],
  "author": "Veli-Matti Viippola <veli-matti.viippola@zetadisplay.com>",
  "license": "MIT",
  "repository": "https://github.com/ZetaDisplay/react-storage-hooks",
  "peerDependencies": {
    "react": "^18.3.1 | ^19.1.1",
    "react-dom": "^18.3.1 | ^19.1.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{md,json}": "prettier --write",
    "*.ts": [
      "prettier --write",
      "eslint --fix",
      "npm run test:staged"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "preset": "ts-jest",
    "testMatch": [
      "**/src/tests/*.test.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/src/tests/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "tsd": {
    "directory": "src"
  },
  "size-limit": [
    {
      "limit": "1.5 kB",
      "path": "dist/index.js"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.16",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "del-cli": "^7.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-test-renderer": "^19.1.1",
    "size-limit": "^11.2.0",
    "ts-jest": "^29.4.4",
    "tsd": "^0.33.0",
    "typescript": "^5.9.2"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
